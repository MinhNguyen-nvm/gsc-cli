{
  "name": "gsc-cli",
  "version": "0.1.0",
  "description": "Google Search Console CLI - Query analytics, inspect URLs, and manage properties",
  "author": "Your Name",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gsc": "./dist/bin/run.js"
  },
  "files": [
    "/bin",
    "/dist"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/run.js",
    "start": "node dist/bin/run.js",
    "dev": "tsx bin/run.ts",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@oclif/core": "^3.27.0",
    "@oclif/plugin-help": "^6.2.20",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "csv-stringify": "^6.5.2",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "open": "^10.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "oclif": {
    "bin": "gsc",
    "dirname": "gsc",
    "commands": "./dist/src/commands",
    "plugins": [
      "@oclif/plugin-help"
    ]
  }
}
